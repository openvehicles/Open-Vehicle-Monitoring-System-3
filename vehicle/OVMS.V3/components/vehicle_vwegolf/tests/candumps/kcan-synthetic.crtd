# Speed    : 0 km/h   (0x0FD d[4:5]=0x00 0x00)
# Gear     : Park     (0x187 d[2]=0x12, nibble & 0x0F = 2)
# Battery  : 0 A / 355 V  (0x191 raw_I=2047, raw_V=1420)
#
# Frame encoding notes:
#   0x486 GPS  d[0..2]=lat bytes, d[3]=lat[26:24]|lon[4:0]<<3,
#              d[4]=lon[12:5], d[5]=lon[20:13], d[6]=0|lon[27:21],
#              d[7]=0 (N/E hemispheres)
#   lat 52516300 us = 0x032155CC  -> CC 55 21, d[3]&0x7=0x03
#   lon 13377700 us = 0x00CC20A4  -> d[3]|=0x20, d[4]=0x05, d[5]=0x61, d[6]=0x06
#
